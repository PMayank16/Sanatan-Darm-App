{
  "expo": {
    "name": "Sanatan-Dharm-App",
    "slug": "Sanatan-Dharm-App",
    "scheme": "sanatandharma",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#4A0404"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.sanatandharm.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#4A0404"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "4810b27e-8309-42a6-bac9-c0c497fe3b42"
      }
    },
    "owner": "mayank16p"
  }
}
